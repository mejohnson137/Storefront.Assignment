<Window x:Class="CKK.UI.AddPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CKK.UI"
        mc:Ignorable="d"
        Title="AddPage" Height="450" Width="800">
    <Grid Background="#7FFF0000">
        <Rectangle HorizontalAlignment="Center" Height="344" Margin="0,36,0,0" Stroke="Black" VerticalAlignment="Top" Width="721" Fill="White"/>
        <Rectangle HorizontalAlignment="Center" Height="256" Stroke="Black" VerticalAlignment="Top" Width="656" Fill="#7FFF8282" Margin="0,86,0,0"/>
        <Label Content="Add Store Item:" HorizontalAlignment="Left" Height="28" Margin="84,53,0,0" VerticalAlignment="Top" Width="202"/>
        <TextBox x:Name="TypeName" HorizontalAlignment="Left" Height="26" Margin="158,117,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="539"/>
        <Label Content="Name:" HorizontalAlignment="Left" Height="25" Margin="110,117,0,0" VerticalAlignment="Top" Width="46"/>
        <Label Content="Price:" HorizontalAlignment="Left" Height="24" Margin="116,164,0,0" VerticalAlignment="Top" Width="40" RenderTransformOrigin="0.228,1.245"/>
        <Label Content="Quantity:" HorizontalAlignment="Left" Height="28" Margin="98,208,0,0" VerticalAlignment="Top" Width="58"/>
        <TextBox x:Name="TypePrice" HorizontalAlignment="Left" Height="26" Margin="158,164,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="539"/>
        <TextBox x:Name="TypeQuantity" HorizontalAlignment="Left" Height="26" Margin="158,208,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="539"/>
        <Button x:Name="CancelButton" Content="Exit" HorizontalAlignment="Left" Height="36" Margin="179,274,0,0" VerticalAlignment="Top" Width="98" Background="#FFFF7878" FontSize="18" Click="CancelButton_Click"/>
        <Button x:Name="AddItem" Content="Add Item" HorizontalAlignment="Left" Height="36" Margin="543,274,0,0" VerticalAlignment="Top" Width="98" Background="White" FontSize="18" Click="AddItem_Click"/>

    </Grid>
</Window>
