<Window x:Class="CKK.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CKK.UI"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Background="#7FFF0202">
        <Grid HorizontalAlignment="Left" Height="5" Margin="590,281,0,0" VerticalAlignment="Top" Width="0"/>
        <Rectangle HorizontalAlignment="Center" Height="340" Stroke="Black" VerticalAlignment="Center" Width="628" Fill="White"/>
        <Label x:Name="name" Content="Username:" HorizontalAlignment="Left" Margin="150,114,0,0" VerticalAlignment="Top" Height="39" Width="102" FontSize="20" RenderTransformOrigin="0.519,1.097"/>
        <Label x:Name="Pass" Content="Password:" HorizontalAlignment="Left" Margin="150,182,0,0" VerticalAlignment="Top" Height="38" Width="102" FontSize="20"/>
        <Button x:Name="Register" Content="Register" HorizontalAlignment="Left" Margin="461,284,0,0" VerticalAlignment="Top" Height="50" Width="93" Background="#FFFFDCDC" FontSize="18" Click="Register_Click"/>
        <Button x:Name="Log_in" Content="Login" HorizontalAlignment="Left" Margin="288,284,0,0" VerticalAlignment="Top" Height="50" Width="101" Background="#FFFF8989" FontSize="18" Click="Log_in_Click"/>
        <PasswordBox x:Name="Password" HorizontalAlignment="Left" Margin="301,182,0,0" VerticalAlignment="Top" Width="352" Height="38" FontSize="18" BorderBrush="Black"/>
        <TextBox x:Name="Username" HorizontalAlignment="Left" Margin="301,114,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="352" Height="38" FontSize="18" BorderBrush="Black"/>

    </Grid>
</Window>
